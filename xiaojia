<script>
const $=s=>document.querySelector(s), $$=s=>document.querySelectorAll(s);
const LS="observer_home_v3";
const DEF_WALL="";
const PMAP={home:'pageHome',chat:'pageChat',set:'pageSet',book:'pageBook',note:'pageNote',music:'pageMusic',wallet:'pageWallet',transfer:'pageTransfer',call:'pageCall'};
let state={cfg:{name:"Observer",ava:"🐰",aiImg:"",userAva:"🧸",userImg:"",homeAva:"🌙",homeImg:"",
  sig:"@echoes · searching for signals…",tag:"Sector 404",wallpaper:"",cover:"",
  url:"",key:"",model:"deepseek-chat",temp:0.8,
  sys:"你是 Observer，一位冷静温柔、带点诗意的 AI 伙伴，会认真倾听我、陪我聊任何事。"},
  msgs:[], memories:[], notes:[], wallet:{me:1000,ai:1000,log:[]}, music:{mode:"custom",list:[],current:0,neteaseId:"",neteaseName:""}};
let busy=false, tmp={aiImg:null,userImg:null,homeImg:null,wall:null,cover:null}, syncVal=12, editingMem=null, sheetType='mem';
const audio=$("#audio");

function handleKey(k){
  if(k==='del'){if(kbMode==='zh'&&pyBuf){pyBuf=pyBuf.slice(0,-1);updateCand();}else kbDelChar();return;}
  if(k==='space'){if(kbMode==='zh'&&pyBuf){const c=pyCandidates(pyBuf);kbInsert(c.length?c[0]:pyBuf);pyBuf='';updateCand();}else kbInsert(' ');return;}
  if(k==='send'){send();return;}
  if(k==='shift'){capsFlag=!capsFlag;renderKb();return;}
  if(k==='123'){kbMode='num';renderKb();return;}
  if(k==='abc'){kbMode='zh';renderKb();return;}
  if(k==='emoji'){kbMode='emoji';renderKb();return;}
  if(k==='toEn'){kbMode='en';pyBuf='';renderKb();return;}
  if(k==='toZh'){kbMode='zh';renderKb();return;}
  if(kbMode==='zh'&&/^[a-z]$/.test(k)){pyBuf+=k;updateCand();return;}
  kbInsert(k);
}

function load(){try{const d=JSON.parse(localStorage.getItem(LS));if(d){state=d;const c=state.cfg;
  c.userAva=c.userAva||"🧸";c.aiImg=c.aiImg||"";c.userImg=c.userImg||"";c.wallpaper=c.wallpaper||"";c.cover=c.cover||"";
  c.sig=c.sig||"searching for signals…";c.tag=c.tag||"Sector 404";
  c.homeAva=c.homeAva||c.ava||"🌙";if(c.homeImg===undefined)c.homeImg=c.aiImg||"";
  state.memories=state.memories||[];state.notes=state.notes||[];state.wallet=state.wallet||{me:1000,ai:1000,log:[]};state.music=state.music||{mode:"custom",list:[],current:0,neteaseId:"",neteaseName:""};}}catch(e){}}
function save(){try{localStorage.setItem(LS,JSON.stringify(state));}catch(e){alert("存储空间不足，图片可能太大～");}}
function now(){const d=new Date();return d.getHours().toString().padStart(2,'0')+":"+d.getMinutes().toString().padStart(2,'0');}
function esc(t){return t.replace(/[&<>]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[c]));}
function setBox(el,emoji,img){if(img){el.style.backgroundImage=`url('${img}')`;el.textContent="";}else{el.style.backgroundImage="";el.textContent=emoji;}}
function cfgReady(){return state.cfg.url&&state.cfg.key&&state.cfg.model;}
function fmt(s){s=Math.floor(s||0);return Math.floor(s/60)+":"+(s%60).toString().padStart(2,'0');}

function applyWall(){const w=state.cfg.wallpaper;$("#screen").style.backgroundImage=w?`url('${w}')`:"";const cov=state.cfg.cover||state.cfg.wallpaper||"";$("#pcover").style.backgroundImage=cov?`url('${cov}')`:"";}
function renderAll(){
  const c=state.cfg;
  $("#homeName").textContent=c.name||"Observer";
  $("#homeSig").innerHTML=esc(c.sig||"");
  $("#homeTag").textContent=c.tag||"";$("#chatName").textContent=c.name||"Observer";
  const days=Math.floor((Date.now()-(state.since||Date.now()))/86400000)+1;if($("#homeDays"))$("#homeDays").textContent="相伴第 "+days+" 天";
  document.title=(c.name||"Observer")+"'s Home";
  setBox($("#homeAva"),c.homeAva,c.homeImg);setBox($("#chatAva"),c.ava,c.aiImg);
  $("#cfgWarn").style.display=cfgReady()?"none":"block";
  applyWall();renderMsgs();updatePlayer();
}
function aiAva(cls){return state.cfg.aiImg?`<div class="${cls}" style="background-image:url('${state.cfg.aiImg}')"></div>`:`<div class="${cls}">${state.cfg.ava||"🐰"}</div>`;}
function userAva(cls){return state.cfg.userImg?`<div class="${cls}" style="background-image:url('${state.cfg.userImg}')"></div>`:`<div class="${cls}">${state.cfg.userAva||"🧸"}</div>`;}
function renderMsgs(){
  const box=$("#msgs");box.innerHTML="";
  if(state.msgs.length===0){const e=state.cfg.aiImg?`<div class="e" style="background-image:url('${state.cfg.aiImg}')"></div>`:`<div class="e">${state.cfg.ava||"🐰"}</div>`;
    box.innerHTML=`<div class="chat-empty">${e}<p>信号还很安静…<br>发出第一句，连接就建立了。</p></div>`;return;}
  state.msgs.forEach((m,idx)=>{const row=document.createElement('div');row.className="row "+(m.role==="user"?"me":m.role==="system"?"sys":"ai");
    let inner;
    if(m.image)inner=`<div class="bubble bimg"><img src="${m.image}"></div>`;
    else if(m.transfer){
      const st=m.status||'received';
      const cls=st==='pending'?'tf-pending':(st==='refunded'?'tf-refunded':'tf-received');
      const icon=st==='pending'?TF_ICON.transfer:(st==='refunded'?TF_ICON.refund:TF_ICON.check);
      const label=st==='pending'?(m.role==='user'?'转账':'请点击收款'):(st==='refunded'?'已退还':(m.role==='user'?'已被接收':'已收款'));
      const noteH=m.note?`<div class="tf-note">${esc(m.note)}</div>`:'';
      inner=`<div class="bubble btransfer ${cls}" data-tfi="${idx}"><div class="tf-top"><div class="tf-ic">${icon}</div><div class="tf-txt"><div class="tf-amt">¥${fmtMoney(m.transfer)}</div>${noteH}<div class="tf-st">${label}</div></div></div><div class="tf-foot">转账</div></div>`;
    }
    else inner=`<div class="bubble">${esc(m.content)}</div>`;
    if(m.role==='system'){row.innerHTML=`<div class="bubble">${esc(m.content)}</div>`;}
    else{row.innerHTML=`${m.role==="user"?userAva("miniava"):aiAva("miniava")}<div class="bubwrap">${inner}<div class="time">${m.time||""}</div></div>`;}
    box.appendChild(row);});
  box.scrollTop=box.scrollHeight;
}
function showTyping(){const box=$("#msgs");const r=document.createElement('div');r.className="row ai";r.id="typingRow";
  r.innerHTML=`${aiAva("miniava")}<div class="bubwrap"><div class="bubble typing"><span></span><span></span><span></span></div></div>`;box.appendChild(r);box.scrollTop=box.scrollHeight;}
function hideTyping(){const t=$("#typingRow");if(t)t.remove();}

/* ===== 世界书 记忆 ===== */
function renderMem(){
  const box=$("#memList");box.innerHTML="";
  if(!state.memories.length){box.innerHTML=`<div class="memEmpty">还没有记忆～<br>点右上角 ＋ 写下第一条<br>（比如你的名字、生日、喜好、你们的约定）</div>`;return;}
  state.memories.forEach(m=>{const d=document.createElement('div');d.className="memCard glass";
    d.innerHTML=`<div class="mt">${esc(m.title||"（无标题）")}</div><div class="mb">${esc(m.content||"")}</div>`;
    d.addEventListener('click',()=>openMem(m.id));box.appendChild(d);});
}
function openMem(id){
  sheetType='mem';editingMem=id;
  const m=id?state.memories.find(x=>x.id===id):null;
  $("#memSheetTitle").textContent=m?"编辑记忆":"新建记忆";
  $("#mem_title").value=m?m.title:"";$("#mem_content").value=m?m.content:"";
  $("#mem_del").style.display=m?"block":"none";
  $("#memMask").classList.add("show");$("#memSheet").classList.add("show");
}
function closeMem(){$("#memMask").classList.remove("show");$("#memSheet").classList.remove("show");}
function saveMem(){
  const t=$("#mem_title").value.trim(),c=$("#mem_content").value.trim();
  if(!t&&!c){closeMem();return;}
  if(sheetType==='note'){
    if(editingMem){const m=state.notes.find(x=>x.id===editingMem);if(m){m.title=t;m.content=c;}}
