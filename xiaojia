<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, interactive-widget=resizes-content">
<title>Observer's Home</title>
<style>
  :root{--ink:#5c6675;--ink2:#8b95a4;--ink3:#aab3c0;--accent:#8ba6c9;
    --glass:rgba(255,255,255,.42);--line:rgba(255,255,255,.55);
    --shadow:0 10px 28px -14px rgba(110,130,165,.45);--user:rgba(139,166,201,.85);}
  *{box-sizing:border-box;-webkit-tap-highlight-color:transparent;margin:0;padding:0;}
  html,body{height:100%;overflow:hidden;}
  body{font-family:"PingFang SC","Hiragino Sans GB","Microsoft YaHei",system-ui,sans-serif;
    background:linear-gradient(160deg,#e9eef3,#dfe6ee 60%,#d6dfe9);
    display:flex;align-items:center;justify-content:center;min-height:100vh;padding:24px;color:var(--ink);position:fixed;inset:0;overflow:hidden;}
  @media (max-width:480px){
    body{padding:0;}
    .phone{width:100vw;height:100vh;height:100dvh;border-radius:0;padding:0;box-shadow:none;}
    .screen{border-radius:0;}
    .island{display:none;}
  }
  .glass{background:var(--glass);backdrop-filter:blur(18px) saturate(1.1);-webkit-backdrop-filter:blur(18px) saturate(1.1);
    border:1px solid var(--line);box-shadow:var(--shadow),inset 0 1px 0 rgba(255,255,255,.6);}
  .mono{font-family:"SF Mono",ui-monospace,Menlo,Consolas,monospace;}
  svg{display:block;}
  .phone{position:relative;width:378px;height:772px;border-radius:52px;
    background:linear-gradient(160deg,#c3ccd8,#aab6c6);padding:13px;
    box-shadow:0 44px 100px -34px rgba(90,110,140,.6),0 0 0 2px rgba(255,255,255,.25) inset;}
  .screen{position:relative;width:100%;height:100%;border-radius:40px;overflow:hidden;display:flex;flex-direction:column;
    background:linear-gradient(160deg,#e6ecf3,#dbe3ed 55%,#cfd9e6) center/cover no-repeat;}
  .screen::before{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(238,242,246,.32),rgba(228,235,243,.5));z-index:0;}
  .island{position:absolute;top:11px;left:50%;transform:translateX(-50%);width:100px;height:25px;background:#1c2027;border-radius:20px;z-index:60;}
  .statusbar{position:relative;z-index:20;height:44px;flex:0 0 44px;display:flex;align-items:flex-end;justify-content:space-between;padding:0 22px 4px;font-size:12.5px;font-weight:600;color:var(--ink);}
  .statusbar .right{display:flex;gap:5px;align-items:center;}
  .bars{display:flex;gap:2px;align-items:flex-end;height:10px;}
  .bars i{width:3px;background:var(--ink);border-radius:1px;}
  .bars i:nth-child(1){height:4px}.bars i:nth-child(2){height:6px}.bars i:nth-child(3){height:8px}.bars i:nth-child(4){height:10px}
  .batt{width:22px;height:11px;border:1.5px solid var(--ink);border-radius:3px;position:relative;}
  .batt::after{content:"";position:absolute;right:-3px;top:3px;width:2px;height:5px;background:var(--ink);border-radius:0 1px 1px 0;}
  .batt i{position:absolute;inset:1.5px;width:74%;background:var(--ink);border-radius:1px;}
  .stage{position:relative;z-index:10;flex:1;overflow:hidden;}
  .page{position:absolute;inset:0;overflow-y:auto;padding:6px 16px 16px;display:none;flex-direction:column;gap:14px;}
  .page.active{display:flex;animation:fade .4s ease;}
  .page::-webkit-scrollbar{width:0;}
  @keyframes fade{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
  /* 主页 */
  .profile{position:relative;border-radius:26px;overflow:hidden;display:flex;flex-direction:column;min-height:240px;justify-content:flex-end;}
  .profile .pcover{position:absolute;inset:0;z-index:0;background:linear-gradient(140deg,#cdd9e8,#bcc9dc 55%,#c8bcd0) center/cover no-repeat;}
  .profile .pmask{position:absolute;left:0;right:0;bottom:0;height:62%;z-index:1;background:linear-gradient(180deg,rgba(255,255,255,0),rgba(255,255,255,.55) 55%,rgba(255,255,255,.85));}
  .profile .ava{position:relative;z-index:2;margin:0 auto;width:86px;height:86px;border-radius:50%;
    background:#dfe7f0 center/cover no-repeat;border:4px solid rgba(255,255,255,.85);box-shadow:0 8px 20px -8px rgba(80,100,135,.7);
    display:flex;align-items:center;justify-content:center;font-size:44px;overflow:hidden;}
  .profile .body{position:relative;z-index:2;text-align:center;padding:12px 20px 18px;}
  .profile .name{font-size:22px;font-weight:700;letter-spacing:1px;}
  .profile .sig{font-size:12.5px;color:var(--ink2);margin-top:8px;line-height:1.7;}
  .profile .sig .cy{color:var(--accent);}
  .profile .tag{display:inline-block;margin-top:10px;font-size:11.5px;color:var(--ink2);}
  .profile .days{font-size:11px;color:var(--accent);margin-top:8px;letter-spacing:.5px;}
  .homerow{display:flex;gap:10px;align-items:stretch;}
  .grid{flex:1;display:grid;grid-template-columns:repeat(2,1fr);gap:10px;}
  .calcard{flex:1;border-radius:20px;padding:12px 10px 10px;display:flex;flex-direction:column;gap:6px;}
  .calcard .cmon{font-size:12px;font-weight:700;color:var(--ink);text-align:center;letter-spacing:.5px;}
  .calcard .cgrid{display:grid;grid-template-columns:repeat(7,1fr);grid-auto-rows:1fr;gap:1px;flex:1;}
  .calcard .cgrid span{font-size:9px;display:flex;align-items:center;justify-content:center;border-radius:5px;color:var(--ink);min-height:16px;}
  .calcard .cgrid .hd{color:var(--ink3);font-weight:700;font-size:8px;}
  .calcard .cgrid .today{background:var(--accent);color:#fff;font-weight:700;}
  .cell{border-radius:20px;padding:15px 4px 11px;display:flex;flex-direction:column;align-items:center;gap:8px;cursor:pointer;transition:transform .15s;color:var(--ink);}
  .cell:active{transform:scale(.93);}
  .cell .ic svg{width:24px;height:24px;}
  .cell .lb{font-size:11px;letter-spacing:.5px;}
  .player{border-radius:22px;padding:14px 16px;display:flex;flex-direction:column;gap:11px;}
  .player .top{display:flex;gap:13px;align-items:center;}
  .player .disc{width:52px;height:52px;border-radius:50%;flex:0 0 52px;background:conic-gradient(#c6d3e4,#dfe7f0,#c6d3e4);position:relative;
    box-shadow:0 4px 12px -5px rgba(110,130,165,.5);animation:spin 8s linear infinite;animation-play-state:paused;}
  .player .disc.playing{animation-play-state:running;}
  .player .disc::after{content:"";position:absolute;inset:40% 40%;background:#eef2f6;border-radius:50%;}
  @keyframes spin{to{transform:rotate(360deg)}}
  .player .info{flex:1;min-width:0;}
  .player .ti{font-size:13.5px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .player .su{font-size:11px;color:var(--ink2);margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .times{display:flex;justify-content:space-between;font-size:10px;color:var(--ink2);}
  .player .bar{height:4px;border-radius:3px;background:rgba(140,160,190,.25);position:relative;overflow:hidden;cursor:pointer;}
  .player .bar b{position:absolute;left:0;top:0;bottom:0;width:0;background:var(--accent);border-radius:3px;}
  .player .ctrl{display:flex;align-items:center;justify-content:center;gap:28px;color:var(--ink);}
  .player .ctrl .cbtn{cursor:pointer;color:var(--ink);}
  .player .ctrl .cbtn svg{width:22px;height:22px;}
  .player .ctrl .pp{width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,.5);display:flex;align-items:center;justify-content:center;cursor:pointer;}
  .player .ctrl .pp svg{width:17px;height:17px;}
  .quote{border-radius:22px;padding:15px 17px;font-size:12px;color:var(--ink2);line-height:1.85;}
  .quote b{color:var(--ink);font-weight:600;display:block;margin-bottom:6px;font-size:12.5px;}
  /* 聊天 & 世界书顶栏 */
  #pageChat,#pageBook{padding:0;gap:0;}
  .chat-top{flex:0 0 auto;display:flex;align-items:center;gap:10px;padding:8px 14px 12px;position:relative;z-index:5;border-radius:0 0 22px 22px;margin:0;}
  .chat-top .back,.chat-top .tool{width:32px;height:32px;border-radius:11px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--ink);}
  .chat-top .back svg{width:20px;height:20px;}.chat-top .tool svg{width:19px;height:19px;color:var(--ink2);}
  .chat-top .cava{width:34px;height:34px;border-radius:50%;overflow:hidden;background:#dfe7f0 center/cover no-repeat;display:flex;align-items:center;justify-content:center;font-size:18px;flex:0 0 34px;}
  .chat-top .meta{flex:1;min-width:0;}
  .chat-top .nm{font-size:15px;font-weight:600;line-height:1.2;}
  .chat-top .stt{font-size:10.5px;color:var(--accent);display:flex;align-items:center;gap:4px;}
  .dot{width:6px;height:6px;border-radius:50%;background:#8fc7a8;box-shadow:0 0 6px #8fc7a8;}
  .messages{flex:1;overflow-y:auto;padding:8px 14px 10px;display:flex;flex-direction:column;gap:13px;}
  .messages::-webkit-scrollbar{width:0;}
  .row{display:flex;gap:8px;align-items:flex-end;max-width:100%;}
  .row.me{flex-direction:row-reverse;}
  .miniava{width:30px;height:30px;border-radius:50%;flex:0 0 30px;overflow:hidden;background:#dfe7f0 center/cover no-repeat;display:flex;align-items:center;justify-content:center;font-size:16px;}
  .bubwrap{max-width:74%;display:flex;flex-direction:column;}
  .row.me .bubwrap{align-items:flex-end;}
  .bubble{padding:10px 13px;border-radius:17px;font-size:14px;line-height:1.65;white-space:pre-wrap;word-break:break-word;animation:pop .25s ease;}
  @keyframes pop{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  .row.ai .bubble{background:rgba(255,255,255,.55);border:1px solid rgba(255,255,255,.6);color:var(--ink);border-bottom-left-radius:5px;backdrop-filter:blur(8px);}
  .row.me .bubble{background:var(--user);color:#fff;border-bottom-right-radius:5px;}
  .time{font-size:10px;color:var(--ink3);margin:4px 4px 0;}
  .typing{display:flex;gap:4px;padding:12px 14px;}
  .typing span{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:tp 1.2s infinite;}
  .typing span:nth-child(2){animation-delay:.2s}.typing span:nth-child(3){animation-delay:.4s}
  @keyframes tp{0%,60%,100%{transform:translateY(0);opacity:.4}30%{transform:translateY(-5px);opacity:1}}
  .chat-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;color:var(--ink2);text-align:center;padding:30px;}
  .chat-empty .e{width:66px;height:66px;border-radius:50%;overflow:hidden;background:#dfe7f0 center/cover no-repeat;display:flex;align-items:center;justify-content:center;font-size:38px;}
  .chat-empty p{font-size:12.5px;line-height:1.7;}
  .composer{flex:0 0 auto;padding:8px 12px 12px;display:flex;gap:8px;align-items:flex-end;}
  .composer .box{flex:1;display:flex;align-items:flex-end;border-radius:22px;padding:5px 6px 5px 15px;background:rgba(255,255,255,.55);border:1px solid rgba(255,255,255,.6);backdrop-filter:blur(8px);}
  .composer textarea{flex:1;resize:none;border:none;background:transparent;outline:none;font-family:inherit;font-size:14px;line-height:1.5;max-height:88px;padding:6px 0;color:var(--ink);}
  .composer .send{width:38px;height:38px;flex:0 0 38px;border:none;border-radius:50%;cursor:pointer;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;transition:transform .15s;}
  .composer .send svg{width:17px;height:17px;}
  .composer .send:active{transform:scale(.9);}.composer .send:disabled{opacity:.5;}
  .warnbar{margin:0 14px 6px;background:rgba(255,250,235,.7);border:1px solid rgba(220,200,150,.5);color:#8a7433;font-size:11.5px;padding:8px 12px;border-radius:12px;line-height:1.6;}
  /* 世界书 */
  .memList{flex:1;overflow-y:auto;padding:8px 14px 14px;display:flex;flex-direction:column;gap:10px;}
  .memList::-webkit-scrollbar{width:0;}
  .memHint{font-size:11.5px;color:var(--ink2);text-align:center;line-height:1.6;padding:2px 20px 6px;}
  .memCard{border-radius:16px;padding:13px 15px;cursor:pointer;transition:transform .15s;}
  .memCard:active{transform:scale(.98);}
  .memCard .mt{font-size:13.5px;font-weight:700;margin-bottom:5px;}
  .memCard .mb{font-size:12px;color:var(--ink2);line-height:1.6;white-space:pre-wrap;}
  .memEmpty{text-align:center;color:var(--ink2);font-size:12.5px;padding:60px 24px;line-height:1.9;}
  .musicItem{display:flex;align-items:center;gap:12px;padding:12px 14px;border-radius:16px;cursor:pointer;transition:transform .15s;}
  .musicItem:active{transform:scale(.98);}
  .musicItem.cur{border:1px solid var(--accent);}
  .musicItem .mi-ic{width:38px;height:38px;border-radius:50%;background:rgba(139,166,201,.18);display:flex;align-items:center;justify-content:center;color:var(--accent);flex:0 0 38px;}
  .musicItem .mi-ic svg{width:16px;height:16px;}
  .musicItem .mi-info{flex:1;min-width:0;}
  .musicItem .mi-tn{font-size:14px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .musicItem .mi-ar{font-size:11px;color:var(--ink2);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  /* + 面板 */
  .plusbtn{width:36px;height:36px;flex:0 0 36px;border-radius:50%;background:rgba(255,255,255,.55);border:1px solid rgba(255,255,255,.6);color:var(--ink);cursor:pointer;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(8px);}
  .plusbtn svg{width:20px;height:20px;transition:transform .25s;}
  .plusbtn.on svg{transform:rotate(45deg);}
  .pluspanel{display:none;padding:14px 18px;gap:16px;flex-wrap:wrap;flex:0 0 auto;}
  .pluspanel.show{display:flex;}
  .pp-item{display:flex;flex-direction:column;align-items:center;gap:6px;cursor:pointer;width:62px;}
  .pp-item:active{transform:scale(.94);}
  .pp-ic{width:56px;height:56px;border-radius:16px;background:rgba(255,255,255,.6);border:1px solid rgba(255,255,255,.5);display:flex;align-items:center;justify-content:center;color:var(--ink);}
  .pp-ic svg{width:26px;height:26px;}
  .pp-item span{font-size:11px;color:var(--ink2);}
  /* 图片 / 转账气泡 */
  .bubble.bimg{padding:4px;}
  .bubble.bimg img{max-width:180px;max-height:220px;border-radius:12px;display:block;}
  .bubble.btransfer{background:#f8a13a!important;color:#fff!important;border:none!important;padding:0!important;min-width:196px;border-radius:8px!important;overflow:hidden;box-shadow:0 2px 8px -4px rgba(210,140,60,.5);}
  .btransfer .tf-top{display:flex;align-items:center;gap:12px;padding:13px 14px 12px;}
  .btransfer .tf-ic{width:34px;height:34px;flex:0 0 34px;}
  .btransfer .tf-ic svg{width:34px;height:34px;}
  .btransfer .tf-amt{font-size:18px;font-weight:700;line-height:1.15;}
  .btransfer .tf-st{font-size:11px;opacity:.92;margin-top:4px;}
  .btransfer .tf-foot{font-size:10px;padding:6px 14px;border-top:1px solid rgba(255,255,255,.28);opacity:.95;}
  .row.sys{justify-content:center;}
  .row.sys .bubble{background:rgba(0,0,0,.06);color:var(--ink2);font-size:11px;padding:4px 10px;border-radius:8px;}
  .btransfer.tf-pending{background:#f8a13a!important;color:#fff!important;}
  .btransfer.tf-received{background:#fbe4c4!important;color:#d38f3c!important;}
  .btransfer.tf-refunded{background:#efe6db!important;color:#b5a082!important;}
  .btransfer .tf-note{font-size:11px;margin-top:3px;opacity:.9;white-space:normal;word-break:break-word;}
  .tnote{width:100%;max-width:280px;border:none;border-bottom:1px solid var(--line);background:transparent;padding:9px 4px;font-size:13px;font-family:inherit;color:var(--ink);outline:none;text-align:center;}
  /* 通话页 */
  .callpage{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:space-between;padding:50px 24px 40px;background:linear-gradient(160deg,#3a4a63 0%,#2c3a52 50%,#1e2a3e 100%);color:#fff;}
  .call-top{text-align:center;}
  .call-status{font-size:13px;opacity:.75;margin-bottom:10px;letter-spacing:1px;}
  .call-name{font-size:24px;font-weight:600;letter-spacing:.5px;}
  .call-time{font-size:14px;margin-top:8px;opacity:.85;font-variant-numeric:tabular-nums;}
  .call-ava{width:128px;height:128px;border-radius:50%;background:#556a8a center/cover no-repeat;display:flex;align-items:center;justify-content:center;font-size:58px;margin-top:14px;box-shadow:0 8px 40px -10px rgba(0,0,0,.6);animation:callPulse 2s ease-in-out infinite;}
  .call-ava.connected{animation:none;}
  @keyframes callPulse{0%,100%{box-shadow:0 8px 40px -10px rgba(0,0,0,.6),0 0 0 0 rgba(255,255,255,.15);}50%{box-shadow:0 8px 40px -10px rgba(0,0,0,.6),0 0 0 24px rgba(255,255,255,0);}}
  .call-btns{display:flex;gap:36px;align-items:center;}
  .call-btn{width:60px;height:60px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;background:rgba(255,255,255,.15);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.12);transition:transform .15s;}
  .call-btn svg{width:26px;height:26px;color:#fff;}
  .call-btn:active{transform:scale(.9);}
  .call-btn.hangup{background:#ff5a5a;border:none;}
  .call-btn.hangup svg{color:#fff;}
  .call-btn.active{background:rgba(255,255,255,.9);}
  .call-btn.active svg{color:#2c3a52;}
  .call-labels{display:flex;gap:36px;justify-content:center;margin-top:10px;font-size:11px;opacity:.7;}
  .call-labels span{width:60px;text-align:center;}
  .callTip{font-size:11px;opacity:.55;margin-top:18px;text-align:center;line-height:1.6;}
  .chat-top .tool.call{margin-right:4px;}
  /* 通话悬浮球 */
  .call-float{position:absolute;top:80px;right:14px;z-index:200;width:56px;height:56px;border-radius:50%;
    background:linear-gradient(160deg,#3a4a63,#1e2a3e);box-shadow:0 6px 20px -6px rgba(0,0,0,.5);
    display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;
    border:2px solid rgba(255,255,255,.25);overflow:hidden;}
  .call-float .cf-ava{width:30px;height:30px;border-radius:50%;background:#556a8a center/cover no-repeat;display:flex;align-items:center;justify-content:center;font-size:16px;}
  .call-float .cf-time{font-size:9px;color:#fff;margin-top:1px;font-variant-numeric:tabular-nums;}
  .call-minbtn{position:absolute;top:14px;left:18px;width:32px;height:32px;border-radius:50%;
    background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;cursor:pointer;
    border:1px solid rgba(255,255,255,.15);z-index:5;}
  .call-minbtn svg{width:18px;height:18px;color:#fff;}
  .call-minbtn:active{background:rgba(255,255,255,.25);}
  /* 钱包 */
  .wpage{padding:0 14px 16px;overflow-y:auto;flex:1;}
  .wpage::-webkit-scrollbar{width:0;}
  .wcard{border-radius:20px;padding:18px;margin-top:12px;}
  .wcard .wlabel{font-size:12px;color:var(--ink2);}
  .wcard .wbal{font-size:34px;font-weight:800;margin-top:6px;letter-spacing:.5px;}
  .wcard .wbal2{font-size:23px;font-weight:700;margin-top:4px;}
  .wcard.mini{padding:14px 18px;}
  .wbtns{display:flex;gap:10px;margin-top:15px;}
  .wbtns button{flex:1;padding:11px;border-radius:12px;border:none;font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;background:var(--accent);color:#fff;}
  .wbtns button.ghost{background:rgba(255,255,255,.6);color:var(--ink);}
  .wlog{display:flex;align-items:center;gap:8px;padding:12px 14px;border-radius:12px;margin-bottom:8px;font-size:13px;}
  .wlog .wl-t{flex:1;}
  .wlog .wl-time{font-size:10px;color:var(--ink3);}
  /* 转账页 */
  .tpage{flex:1;overflow-y:auto;display:flex;flex-direction:column;align-items:center;padding:22px 24px;gap:15px;}
  .tpage::-webkit-scrollbar{width:0;}
  .trecv{display:flex;flex-direction:column;align-items:center;gap:10px;}
  .tava{width:64px;height:64px;border-radius:50%;background:#dfe7f0 center/cover no-repeat;display:flex;align-items:center;justify-content:center;font-size:32px;overflow:hidden;border:2px solid rgba(255,255,255,.7);}
  .tname{font-size:15px;font-weight:600;}
  .tamount{display:flex;align-items:center;gap:6px;border-bottom:2px solid var(--accent);padding:6px 0;width:100%;max-width:260px;justify-content:center;}
  .tcur{font-size:30px;font-weight:700;}
  .tamount input{border:none;background:transparent;outline:none;font-size:42px;font-weight:700;font-family:inherit;color:var(--ink);width:64%;text-align:center;}
  .tconfirm{width:100%;max-width:280px;padding:14px;border-radius:14px;border:none;background:var(--accent);color:#fff;font-size:15px;font-weight:700;cursor:pointer;font-family:inherit;box-shadow:0 8px 18px -9px var(--accent);}
