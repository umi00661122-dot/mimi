function saveCfg(){
  const c=state.cfg;
  c.name=$("#f_name").value.trim()||"Observer";c.ava=$("#f_ava").value.trim()||"🐰";c.userAva=$("#f_userava").value.trim()||"🧸";c.homeAva=$("#f_homeava").value.trim()||"🌙";
