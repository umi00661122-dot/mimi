function compressAva(file,cb){imgLoad(file,img=>{const s=Math.min(img.width,img.height),z=256,c=document.createElement('canvas');c.width=z;c.height=z;c.getContext('2d').drawImage(img,(img.width-s)/2,(img.height-s)/2,s,s,0,0,z,z);cb(c.toDataURL('image/jpeg',.82));});}
function compressWall(file,cb){imgLoad(file,img=>{const mx=900,sc=Math.min(1,mx/Math.max(img.width,img.height)),w=Math.round(img.width*sc),h=Math.round(img.height*sc),c=document.createElement('canvas');c.width=w;c.height=h;c.getContext('2d').drawImage(img,0,0,w,h);cb(c.toDataURL('image/jpeg',.8));});}
function imgLoad(file,fn){if(file.size>10*1024*1024){alert("图片太大，换张小于 10MB 的～");return;}const rd=new FileReader();rd.onload=e=>{const img=new Image();img.onload=()=>fn(img);img.src=e.target.result;};rd.readAsDataURL(file);}

function bind(){
