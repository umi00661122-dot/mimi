  $("#m_add").addEventListener('click',()=>{const url=$("#m_url").value.trim();if(!url){toast("先填音频直链 URL");return;}
    state.music.list.push({name:$("#m_name").value.trim()||"未命名",artist:$("#m_artist").value.trim(),url});save();
    $("#m_name").value="";$("#m_artist").value="";$("#m_url").value="";renderTrackList();updatePlayer();toast("已添加到歌单");});
  $("#m_file").addEventListener('change',e=>{const f=e.target.files[0];if(f){audio.src=URL.createObjectURL(f);$("#mTi").textContent=f.name.replace(/\.[^.]+$/,'');$("#mSu").textContent="本地试听";audio.play();}});
  // 播放控制
  $("#pp").addEventListener('click',togglePlay);
  $("#btnPrev").addEventListener('click',()=>loadTrack(state.music.current-1,true));
  $("#btnNext").addEventListener('click',()=>loadTrack(state.music.current+1,true));
  $("#progBar").addEventListener('click',e=>{if(audio.duration){const r=e.currentTarget.getBoundingClientRect();audio.currentTime=(e.clientX-r.left)/r.width*audio.duration;}});
  audio.addEventListener('timeupdate',()=>{if(audio.duration){$("#progB").style.width=(audio.currentTime/audio.duration*100)+"%";$("#curT").textContent=fmt(audio.currentTime);$("#durT").textContent=fmt(audio.duration);}});
  audio.addEventListener('play',()=>{$("#disc").classList.add('playing');setPP(true);renderMusicPage();});
  audio.addEventListener('pause',()=>{$("#disc").classList.remove('playing');setPP(false);renderMusicPage();});
  audio.addEventListener('ended',()=>{if(state.music.list.length>1)loadTrack(state.music.current+1,true);});
}
function toast(msg){const t=document.createElement('div');t.textContent=msg;
  t.style.cssText="position:absolute;left:50%;bottom:92px;transform:translateX(-50%);z-index:99;background:rgba(60,70,85,.85);color:#fff;font-size:12px;padding:9px 16px;border-radius:20px;backdrop-filter:blur(6px);";
  $("#screen").appendChild(t);setTimeout(()=>t.remove(),1800);}
function renderCal(){
  const now=new Date(),y=now.getFullYear(),mo=now.getMonth(),d=now.getDate();
  const mons=["一月","二月","三月","四月","五月","六月","七月","八月","九月","十月","十一月","十二月"];
  const wks=["日","一","二","三","四","五","六"];
  let h=`<div class="cmon">${y} · ${mons[mo]}</div><div class="cgrid">`;
  wks.forEach(w=>h+=`<span class="hd">${w}</span>`);
  const first=new Date(y,mo,1).getDay(),days=new Date(y,mo+1,0).getDate();
  for(let i=0;i<first;i++)h+=`<span></span>`;
  for(let dd=1;dd<=days;dd++)h+=`<span class="${dd===d?'today':''}">${dd}</span>`;
  h+=`</div>`;$("#calCard").innerHTML=h;
}
