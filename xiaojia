  $("#speakerBtn").addEventListener('click',()=>{callSpeaker=!callSpeaker;$("#speakerBtn").classList.toggle('active',callSpeaker);toast(callSpeaker?'免提开启':'免提关闭');});
  $("#minCallBtn").addEventListener('click',minimizeCall);
  // 悬浮球：拖动 + 点击恢复
  (function(){
    const ball=$("#callFloat");let dragging=false,startX=0,startY=0,ox=0,oy=0,moved=false;
    function phoneRect(){return document.querySelector('.phone').getBoundingClientRect();}
    function onDown(e){
      dragging=true;moved=false;
      const t=e.touches?e.touches[0]:e;
      startX=t.clientX;startY=t.clientY;
      const r=ball.getBoundingClientRect(),pr=phoneRect();
      ox=r.left-pr.left;oy=r.top-pr.top;
      e.preventDefault();
    }
    function onMove(e){
      if(!dragging)return;moved=true;
      const t=e.touches?e.touches[0]:e;
      const dx=t.clientX-startX,dy=t.clientY-startY;
      const pr=phoneRect();
      const maxX=pr.width-58,maxY=pr.height-58;
      const nx=Math.max(4,Math.min(maxX,ox+dx)),ny=Math.max(4,Math.min(maxY,oy+dy));
      ball.style.left=(pr.left+nx)+'px';ball.style.top=(pr.top+ny)+'px';ball.style.right='auto';
      e.preventDefault();
    }
    function onUp(e){
      if(!dragging)return;dragging=false;
      if(!moved){go('call');return;}
      const pr=phoneRect(),r=ball.getBoundingClientRect();
      const cx=r.left-pr.left+r.width/2;
      if(cx<pr.width/2)ball.style.left=(pr.left+4)+'px';
      else ball.style.left=(pr.left+pr.width-60)+'px';
      ball.style.right='auto';
    }
    ball.addEventListener('mousedown',onDown);document.addEventListener('mousemove',onMove);document.addEventListener('mouseup',onUp);
    ball.addEventListener('touchstart',onDown,{passive:false});
    ball.addEventListener('touchmove',onMove,{passive:false});
    ball.addEventListener('touchend',onUp);
    window.addEventListener('resize',()=>{if(ball.style.display!=='none'){const pr=phoneRect();ball.style.left=(pr.left+pr.width-60)+'px';}});
  })();
  $("#sendBtn").addEventListener('click',send);
  $("#input").addEventListener('keydown',e=>{if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();send();}});
  $("#input").addEventListener('input',function(){this.style.height="auto";this.style.height=Math.min(this.scrollHeight,88)+"px";});
