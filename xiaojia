async function sendToAI(){
  if(busy)return;if(!cfgReady()){go('set');return;}
  busy=true;$("#sendBtn").disabled=true;showTyping();
  let sys=state.cfg.sys||"";
  if(state.memories.length)sys+="\n\n【档案馆 · 长期记忆，请自然地记住并运用，不要生硬复述】\n"+state.memories.map(m=>`· ${m.title?m.title+"：":""}${m.content}`).join("\n");
  sys+="\n\n【备忘录能力】当我请你把某件事 / 待办 / 约定记到备忘录时，请在回复里用 <备忘>具体内容</备忘> 包裹（可多条），系统会自动存进备忘录；标记以外的内容正常回复。";
  sys+="\n\n【虚拟钱包】这是一个好玩的虚拟余额（非真实货币）。当你想给我转账时，在回复里用 <转账>数字</转账> 标记（我可以选择收下或退还）。当我给你转账（会显示为「待你领取」）时，你可以决定：想收下就在回复里加 <收款/>，想退还就加 <退款/>（一次最多处理一笔），并自然地回应我。以上标记以外的内容正常回复。";
  const msgs=state.msgs.filter(m=>m.role!=='system').map(m=>{
    if(m.image)return {role:m.role,content:[{type:"text",text:m.content||"请看这张图片"},{type:"image_url",image_url:{url:m.image}}]};
    if(m.transfer){const tag=m.status==='refunded'?'（已退还）':m.status==='received'?'（已收款）':(m.role==='user'?'（待你领取，可回复 <收款/> 或 <退款/> 处理）':'（待我领取）');return {role:m.role,content:`[${m.role==='user'?'我给你转了':'你给我转了'} ¥${m.transfer} 虚拟金额]${tag}`};}
    return {role:m.role,content:m.content};
  });
  const payload={model:state.cfg.model,temperature:parseFloat(state.cfg.temp)||0.8,messages:[{role:"system",content:sys},...msgs]};
  try{
    const res=await fetch(state.cfg.url,{method:"POST",headers:{"Content-Type":"application/json","Authorization":"Bearer "+state.cfg.key},body:JSON.stringify(payload)});
    if(!res.ok){const t=await res.text();throw new Error("接口返回 "+res.status+"："+t.slice(0,200));}
    const data=await res.json();let reply=data?.choices?.[0]?.message?.content||"(没有收到内容)";
    let added=false;const noteRe=/<备忘>([\s\S]*?)<\/备忘>/g;let mm;
    while((mm=noteRe.exec(reply))){const tx=mm[1].trim();if(tx){state.notes.push({id:Date.now().toString()+Math.random().toString(36).slice(2,5),title:"",content:tx,by:"ai",time:noteTime()});added=true;}}
    reply=reply.replace(/<备忘>[\s\S]*?<\/备忘>/g,'');
    const trRe=/<转账>\s*([\d.]+)\s*<\/转账>/g;let tm,trAmt=0;
    while((tm=trRe.exec(reply))){const n=parseFloat(tm[1]);if(!isNaN(n)&&n>0)trAmt+=n;}
    reply=reply.replace(/<转账>[\s\S]*?<\/转账>/g,'');
    let payAct='';if(/<收款\/>/.test(reply))payAct='accept';if(/<退款\/>/.test(reply))payAct='refund';
    reply=reply.replace(/<收款\/>/g,'').replace(/<退款\/>/g,'').trim();
    if(payAct){for(let i=state.msgs.length-1;i>=0;i--){const p=state.msgs[i];if(p.transfer&&p.role==='user'&&p.status==='pending'){if(payAct==='accept')p.status='received';else{p.status='refunded';state.wallet.me+=p.transfer;state.wallet.ai-=p.transfer;}break;}}}
    hideTyping();
    if(reply)state.msgs.push({role:"assistant",content:reply,time:now()});
    else if((added||payAct)&&trAmt===0)state.msgs.push({role:"assistant",content:"好的～",time:now()});
    save();renderMsgs();renderWallet();
    if(trAmt>0)aiTransfer(trAmt,'');
  }catch(err){hideTyping();let tip=err.message||String(err);
    if(tip.includes("Failed to fetch"))tip="连不上接口 😢 可能地址写错，或该接口不允许网页直接调用(CORS)。可换支持浏览器调用的中转地址，或按教程搭后端。";
    state.msgs.push({role:"assistant",content:"⚠️ "+tip,time:now()});save();renderMsgs();
  }finally{busy=false;$("#sendBtn").disabled=false;}
}

