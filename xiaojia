  $("#clr_ai").addEventListener('click',()=>{tmp.aiImg="";refreshPv();});
  $("#clr_home").addEventListener('click',()=>{tmp.homeImg="";refreshPv();});
  $("#clr_me").addEventListener('click',()=>{tmp.userImg="";refreshPv();});
  $("#clr_wall").addEventListener('click',()=>{tmp.wall="";refreshPv();});
  $("#clr_cover").addEventListener('click',()=>{tmp.cover="";refreshPv();});
  $("#f_ava").addEventListener('input',refreshPv);$("#f_userava").addEventListener('input',refreshPv);$("#f_homeava").addEventListener('input',refreshPv);
  // 音乐
  $("#seg_custom").addEventListener('click',()=>switchMode("custom"));
